# ══════════════════════════════════════════════════════
#  Trading Survivor — Variables de Entorno
#  Copia este archivo a .env para desarrollo local
#  En producción, configura en:
#  Vercel Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════

# ─── SUPABASE (base de datos y auth) ──────────────────
# https://supabase.com → Project → Settings → API
# Usa la "service_role" key (NO la anon key)
SUPABASE_URL=https://gakiamardmlgftfrlxkm.supabase.co
SUPABASE_SERVICE_KEY=REEMPLAZA_CON_TU_SERVICE_ROLE_KEY

# ─── STRIPE (pagos con tarjeta) ───────────────────────
# https://dashboard.stripe.com/apikeys
# TEST:  sk_test_...   |   LIVE: sk_live_...
STRIPE_SECRET_KEY=sk_live_REEMPLAZA_CON_TU_STRIPE_SECRET_KEY
# https://dashboard.stripe.com/webhooks → tu webhook → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZA_CON_TU_WEBHOOK_SECRET

# ─── GEMINI (AI Coach) ────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=REEMPLAZA_CON_TU_GEMINI_API_KEY

# ─── RESEND (emails transaccionales) ──────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_REEMPLAZA_CON_TU_RESEND_API_KEY

# ─── ADMIN ────────────────────────────────────────────
# Secreto para acceder al panel /admin — inventa una cadena larga y aleatoria
ADMIN_SECRET=REEMPLAZA_CON_UN_SECRETO_LARGO_Y_ALEATORIO
# Email del admin para notificaciones internas
ADMIN_EMAIL=admintradingsurvivor@gmail.com

# ─── DOMINIO Y CORS ──────────────────────────────────
# URL pública de la plataforma (sin trailing slash)
APP_URL=https://tudominio.com
# Dominios autorizados separados por coma (Vercel preview + producción)
APP_DOMAIN=https://tudominio.com,https://trading-survivor-dsft.vercel.app
# Origen permitido para el checkout de Stripe
ALLOWED_ORIGIN=https://tudominio.com

# IMPORTANTE: Las API keys de exchanges las guarda Supabase (user_settings)
# NUNCA las pongas aquí por seguridad

